<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.wanderlens.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_upload"
        android:name="com.example.wanderlens.ui.upload.UploadFragment"
        android:label="Upload"
        tools:layout="@layout/fragment_upload" />

    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.wanderlens.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />
        
    <fragment
        android:id="@+id/nav_ai_processing"
        android:name="com.example.wanderlens.ui.upload.AiProcessingFragment"
        android:label="Processing"
        tools:layout="@layout/fragment_ai_processing" />
        
    <fragment
        android:id="@+id/nav_detail"
        android:name="com.example.wanderlens.ui.detail.JournalDetailFragment"
        android:label="Detail"
        tools:layout="@layout/fragment_journal_detail">
        <argument
            android:name="journalId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.example.wanderlens.ui.profile.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
